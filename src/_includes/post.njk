---
layout: base.njk
---
<div class="post-layout">
    <article class="blog-post">
        <header class="post-header">
            <h1>{{ title }}</h1>
            <!-- Eleventy automatically formats dates -->
            <p class="post-date">Published on: {{ date.toDateString() }}</p> 
        </header>

        <div class="post-content">
            {{ content | safe }}
        </div>
    </article>

    <!-- Sidebar for Desktop / Bottom for Mobile -->
    <aside class="sidebar">
        <div class="ad-slot vertical-ad">
            <p class="ad-label">Advertisement</p>
            <!-- Paste Vertical Google Ad here later -->
        </div>
    </aside>
</div>