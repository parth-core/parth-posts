<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Primary Meta -->
    <title>{{ title | default("Parth Posts — Tech, AI & Web") }}</title>
    <meta name="description" content="{{ description | default('Deep dives into Artificial Intelligence, web development, and the tools shaping our digital world. Written by Parth.') }}">
    <meta name="author" content="Parth">

    <!-- Open Graph -->
    <meta property="og:title" content="{{ title | default('Parth Posts') }}">
    <meta property="og:description" content="{{ description | default('Deep dives into AI, web development, and digital tools.') }}">
    <meta property="og:type" content="{{ 'article' if layout == 'post.njk' else 'website' }}">
    <meta property="og:site_name" content="Parth Posts">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ title | default('Parth Posts') }}">
    <meta name="twitter:description" content="{{ description | default('Deep dives into AI, web development, and digital tools.') }}">

    <!-- Canonical -->
    <link rel="canonical" href="{{ page.url | url }}">

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">

    <!-- Styles -->
    <link rel="stylesheet" href="{{ '/css/style.css' | url }}">

    <!-- Google AdSense — paste your script tag here when approved -->
    <!-- <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX" crossorigin="anonymous"></script> -->

    <!-- Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Blog",
      "name": "Parth Posts",
      "description": "Deep dives into AI, web development, and digital tools.",
      "author": { "@type": "Person", "name": "Parth" }
    }
    </script>
</head>
<body>

<!-- Reading progress bar (only shown on post pages) -->
<div class="reading-progress" id="reading-progress"></div>

<!-- ===== HEADER ===== -->
<header class="site-header" id="site-header">
    <div class="header-inner">
        <!-- Left nav -->
        <nav class="header-left" aria-label="Primary navigation">
            <a href="{{ '/' | url }}" class="nav-link {% if page.url == '/' %}active{% endif %}">Home</a>
            <a href="#" class="nav-link">Topics</a>
            <a href="#" class="nav-link">About</a>
        </nav>

        <!-- Logo (center) -->
        <a href="{{ '/' | url }}" class="logo" aria-label="Parth Posts home">
            Parth<span class="logo-dot">.</span>Posts
            <span class="logo-sub">Tech &amp; AI</span>
        </a>

        <!-- Right controls -->
        <div class="header-right">
            <button class="theme-btn" id="theme-toggle" aria-label="Toggle dark mode" title="Toggle theme">
                <span id="theme-icon">🌙</span>
            </button>
        </div>
    </div>
    <div class="header-divider"></div>
</header>

<!-- ===== MAIN CONTENT ===== -->
<main id="main-content">
    {{ content | safe }}
</main>

<!-- ===== FOOTER ===== -->
<footer class="site-footer">
    <div class="container">
        <div class="footer-top">
            <div class="footer-brand">
                <a href="{{ '/' | url }}" class="logo">Parth<span class="logo-dot">.</span>Posts</a>
                <p class="footer-desc">
                    Honest writing on AI, web development, and the tools reshaping how we work and think online.
                </p>
            </div>

            <div>
                <p class="footer-col-title">Navigation</p>
                <ul class="footer-links">
                    <li><a href="{{ '/' | url }}">Home</a></li>
                    <li><a href="#">About</a></li>
                    <li><a href="#">Topics</a></li>
                    <li><a href="#">RSS Feed</a></li>
                </ul>
            </div>

            <div>
                <p class="footer-col-title">Topics</p>
                <ul class="footer-links">
                    <li><a href="#">Artificial Intelligence</a></li>
                    <li><a href="#">Web Development</a></li>
                    <li><a href="#">Productivity</a></li>
                    <li><a href="#">Tools &amp; Workflow</a></li>
                </ul>
            </div>
        </div>

        <div class="footer-bottom">
            <p class="footer-copy">
                &copy; 2025 <span>Parth Posts</span>. Built with 11ty &amp; pure code.
            </p>
            <nav class="footer-legal" aria-label="Legal links">
                <a href="#">Privacy Policy</a>
                <a href="#">Terms</a>
            </nav>
        </div>
    </div>
</footer>

<script src="{{ '/js/main.js' | url }}"></script>
</body>
</html>
